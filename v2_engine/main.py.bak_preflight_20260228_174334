def get_bankroll(conn):
    row = conn.execute("""
        SELECT bankroll
        FROM paper_ledger
        ORDER BY timestamp DESC
        LIMIT 1
    """).fetchone()
    return row[0] if row else 10000


def get_total_exposure(conn):
    row = conn.execute("""
        SELECT COALESCE(SUM(size_usd), 0)
        FROM paper_positions
        WHERE status='open'
    """).fetchone()
    return row[0] if row else 0


def get_equity_history(conn):
    rows = conn.execute("""
        SELECT bankroll
        FROM paper_ledger
        ORDER BY timestamp ASC
    """).fetchall()
    return [r[0] for r in rows] if rows else [10000]


def compute_drawdown(equity_history):
    peak = max(equity_history)
    current = equity_history[-1]
    return (peak - current) / peak if peak > 0 else 0


def fetch_recent_signals(conn):
    return conn.execute("""
        SELECT t.wallet_address,
               t.market_slug,
               t.outcome,
               t.side,
               t.price,
               w.alpha_score
        FROM trades t
        JOIN wallets w
        ON t.wallet_address = w.address
        WHERE t.timestamp > strftime('%s','now') - 300
    """).fetchall()


def main():
    conn = _connect_db()
    conn = _connect_db()
    _db_preflight(conn)


    bankroll = get_bankroll(conn)
    total_exposure = get_total_exposure(conn)
    equity_history = get_equity_history(conn)
    drawdown = compute_drawdown(equity_history)

    signals = fetch_recent_signals(conn)

    for wallet, slug, outcome, side, price, score in signals:

        valid, edge = edge_is_valid(score, price)
        if not valid:
            continue

        proposed_size = bankroll * 0.01

        approved, result = approve_trade(
            bankroll,
            proposed_size,
            drawdown,
            total_exposure,
            theme_exposure=0
        )

        if approved:
            insert_paper_trade(
                conn, wallet, slug, outcome,
                side, price, result
            )

    print(f"[RUN COMPLETE] DD={drawdown:.2%} Exposure={total_exposure:.2f}")


if __name__ == "__main__":
    main()

def _db_preflight(conn):
    import os
    print("[PRE] cwd:", os.getcwd())
    try:
        dbfile = conn.execute("PRAGMA database_list").fetchall()
        print("[PRE] db:", dbfile)
    except Exception as e:
        print("[PRE] dblist error:", e)

    tables = {r[0] for r in conn.execute("SELECT name FROM sqlite_master WHERE type='table'")}
    missing = ['paper_ledger', 'paper_positions', 'trades', 'wallets'].__class__(['paper_ledger', 'paper_positions', 'trades', 'wallets'])  # noop to keep patch simple
    missing = ['paper_ledger', 'paper_positions', 'trades', 'wallets']  # overwritten below

    required = {'paper_positions', 'wallets', 'trades', 'paper_ledger'}
    missing = required - tables
    print("[PRE] tables:", sorted(tables))
    if missing:
        raise SystemExit("[FATAL] DB missing tables: " + ", ".join(sorted(missing)) + "  (wrong DB opened)")
    print("[PRE] DB OK")
