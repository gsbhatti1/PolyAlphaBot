def _db_preflight(conn):
    import os
    required = {"paper_ledger","paper_positions","wallets","trades"}
    print("[PRE] cwd:", os.getcwd())
    print("[PRE] db:", conn.execute("PRAGMA database_list").fetchall())
    tables = {r[0] for r in conn.execute("SELECT name FROM sqlite_master WHERE type='table'")}
    print("[PRE] tables:", sorted(tables))
    missing = required - tables
    if missing:
        raise SystemExit("[FATAL] wrong DB opened; missing: " + ", ".join(sorted(missing)))
    print("[PRE] DB OK")


