def get_bankroll(conn):
    row = conn.execute("""
        SELECT bankroll
        FROM paper_ledger
        ORDER BY timestamp DESC
        LIMIT 1
    """).fetchone()
    return row[0] if row else 10000


def get_total_exposure(conn):
    row = conn.execute("""
        SELECT COALESCE(SUM(size_usd), 0)
        FROM paper_positions
        WHERE status='open'
    """).fetchone()
    return row[0] if row else 0


def get_equity_history(conn):
    rows = conn.execute("""
        SELECT bankroll
        FROM paper_ledger
        ORDER BY timestamp ASC
    """).fetchall()
    return [r[0] for r in rows] if rows else [10000]


def compute_drawdown(equity_history):
    peak = max(equity_history)
    current = equity_history[-1]
    return (peak - current) / peak if peak > 0 else 0


def fetch_recent_signals(conn):
    return conn.execute("""
        SELECT t.wallet_address,
               t.market_slug,
               t.outcome,
               t.side,
               t.price,
               w.alpha_score
        FROM trades t
        JOIN wallets w
        ON t.wallet_address = w.address
        WHERE t.timestamp > strftime('%s','now') - 300
    """).fetchall()


